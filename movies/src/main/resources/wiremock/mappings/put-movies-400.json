{
  "request": {
    "method": "PUT",
    "urlPattern": "/movies/([0-9]+)",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$[?(@.title == '')]"
      }
    ]
  },
  "response": {
    "status": 400,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "code": 400,
      "title": "bad-request",
      "message": "Validation error",
      "errors": {
        "title": "Title cannot be empty"
      }
    }
  }
}
